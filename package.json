{
  "name": "steamates-backend",
  "version": "1.0.0",
  "description": "SteaMates Backend - Express.js + MongoDB + Groq AI + Steam API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "swagger": "node swagger.js",
    "start": "npm run swagger && node src/index.js",
    "dev": "npm run swagger && node --watch src/index.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/",
    "lint:report": "eslint src/ --format json > eslint-report.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.3.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "groq-sdk": "^0.8.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^8.9.5",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.18",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "jest": "^30.4.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/routes/**/*.js",
      "src/controllers/**/*.js",
      "src/models/**/*.js"
    ],
    "moduleNameMapper": {
      "^abort-controller$": "<rootDir>/tests/abortMock.js",
      "^connect-mongo$": "<rootDir>/tests/mongoMock.js"
    }
  }
}
